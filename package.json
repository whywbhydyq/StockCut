{
  "name": "stockcut",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.9.2",
  "scripts": {
    "dev": "next dev",
    "build": "npm run typecheck && next build --no-lint",
    "start": "next start",
    "lint": "npm run typecheck && node scripts/validate-site.mjs",
